# Телеграм и права администратора
BOT_TOKEN=<YOUR:TELEGRAM_BOT_TOKEN> # @BotFather
ADMIN_IDS=<YOUR:TELEGRAM-ID> # @userinfobot
BACKUP_CHAT_ID=<YOUR:TELEGRAM-ID_PRIVATE-GROUP> # @userinfobot
# Можете оставить значение пустым. В таком случае всё будет отправляться в личные сообщения с ботом.

# Шифрование
# Используйте следующую команду, для генерации своего Fernet-ключа:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=<YOUR:FERNET_CRYPTO-KEY>

# Режим разработки и тестирования
# Раскомментируйте переменные ниже для переключения в режим песочницы:
# DEV_MODE=True         # Активирует заглушки вместо подключения к реальным серверам.
# DB_DIR=data_dev       # Создает БД в отдельной папке, чтобы изолировать её.

# Ноды AmneziaWG
WG_API_URL_1=http://<NODE1_IP>:51823
WG_PASSWORD_1=<YOUR:AWG-EASY_PASSWORD>
WG_API_NAME_1=RU # ccTLD
WG_API_URL_2=http://<NODE2_IP>:51823
WG_PASSWORD_2=<YOUR:AWG-EASY_PASSWORD>
WG_API_NAME_2=NL # ccTLD

# MTPROTO-MANAGER SIDECARS
MTPROTO_MGR_URL_1=http://<NODE1_IP>:8000
MTPROTO_HOST_1=<NODE1_IP>
MTPROTO_PORT_1=443
MTPROTO_MGR_URL_2=http://<NODE2_IP>:8000
MTPROTO_HOST_2=<NODE2_IP>
MTPROTO_PORT_2=443

# Подписка
SUBSCRIPTION_DAYS=30
PAYMENT_EXPIRE_HOURS=24

# Split-Tunnel
SPLIT_TUNNEL_URL=https://raw.githubusercontent.com/1andrevich/Re-filter-lists/main/ipsum.lst
SPLIT_TUNNEL_UPDATE_HOURS=24

# Мобильный компактный CIDR
COMPACT_MOBILE_CIDRS=31.13.64.0/18,157.240.0.0/16,185.60.216.0/22,104.244.32.0/20,199.16.156.0/22,192.44.69.0/24,142.250.0.0/15,172.217.0.0/16,216.58.192.0/19,74.125.0.0/16,108.177.0.0/17,13.32.0.0/15,13.35.0.0/16,52.84.0.0/15,54.230.0.0/16,18.64.0.0/10,18.128.0.0/9,104.16.0.0/12,172.64.0.0/13,162.159.0.0/16,141.101.64.0/18,140.82.112.0/20,185.199.108.0/22,192.30.252.0/22,20.201.28.0/22,20.205.243.0/24,20.190.128.0/18,40.64.0.0/10,34.96.0.0/14,34.100.0.0/13,35.190.0.0/17,13.224.0.0/12,13.249.0.0/16,205.251.192.0/18,151.101.0.0/16,185.42.204.0/22,192.108.239.0/24,104.18.0.0/15,162.125.0.0/16,13.107.42.0/24,140.82.121.0/24,104.18.0.0/20

